            <div><div class="dr-lbl">Date</div><div class="dr-val">${date}</div></div>
            <div><div class="dr-lbl">Time</div><div class="dr-val">${time}</div></div>
            <div><div class="dr-lbl">Order</div><div class="dr-val">#${lastOrderNum}</div></div>
            <div><div class="dr-lbl">Cashier</div><div class="dr-val">Marcus T.</div></div>
          </div>
          <div class="dr-sep"></div>
          <div class="dr-ih"><span>Items</span><span>Amount</span></div>
          ${items.map(i => `
            <div class="dr-item">
              <div class="dr-il"><span class="dr-iq">${i.qty}</span><div><div class="dr-in">${i.name}</div><div class="dr-im">${i.size} · $${i.price.toFixed(2)} ea</div></div></div>
              <span class="dr-ip">$${(i.price*i.qty).toFixed(2)}</span>
            </div>
          `).join('')}
          <div class="dr-sep dash"></div>
          <div class="dr-totals">
            <div class="dr-tr"><span>Subtotal</span><span>$${sub.toFixed(2)}</span></div>
            <div class="dr-tr"><span>Tax (9.75%)</span><span>$${tx.toFixed(2)}</span></div>
            <div class="dr-tr main"><span>Total</span><span class="dr-ta">$${tot.toFixed(2)}</span></div>
          </div>
          <div class="dr-pay">✓ ${payLabels[payMethod]} · Approved</div>
          ${customerAdded ? `<div class="dr-loyalty"><span class="dr-l-i">⭐</span><div><div class="dr-l-t">+${pts} points earned</div><div class="dr-l-p">Balance: ${(2432+pts).toLocaleString()} pts</div></div></div>` : ''}
        </div>
        <div class="dr-foot">
          <div class="dr-fm">Thank you for your purchase!</div>
          <div class="dr-fs">123 Bourbon St, Nashville, TN · (615) 555-0142</div>
        </div>
      </div>`;
  } else {
    body.innerHTML = `
      <div class="p-receipt-wrap">
        <div class="p-receipt">
          <div class="pr-c">
            <div class="pr-logo">SPIRITS IQ</div>
            <div class="pr-tag">PREMIUM SPIRITS</div>
            <div class="pr-addr">123 Bourbon St<br>Nashville, TN 37203<br>(615) 555-0142</div>
          </div>
          <hr class="pr-sep dbl">
          <div class="pr-row"><span>${date}</span><span>${time}</span></div>
          <div class="pr-row"><span>Order #${lastOrderNum}</span><span>Marcus T.</span></div>
          ${customerAdded ? '<div class="pr-row"><span>Customer: James W.</span><span>Loyalty ★</span></div>' : ''}
          <hr class="pr-sep">
          ${items.map(i => `
            <div style="margin-bottom:5px">
              <div class="pr-item-name">${i.name} ${i.size}</div>
              <div class="pr-item-d"><span>${i.qty} x $${i.price.toFixed(2)}</span><span>$${(i.price*i.qty).toFixed(2)}</span></div>
            </div>
          `).join('')}
          <hr class="pr-sep">
          <div class="pr-total-row"><span>Subtotal</span><span>$${sub.toFixed(2)}</span></div>
          <div class="pr-total-row"><span>Tax 9.75%</span><span>$${tx.toFixed(2)}</span></div>
          <hr class="pr-sep">
          <div class="pr-total-row pr-total-big"><span>TOTAL</span><span>$${tot.toFixed(2)}</span></div>
          <hr class="pr-sep">
          <div class="pr-row"><span>${payMethod==='card'?'VISA ***4242':payMethod==='cash'?'CASH':' PAY'}</span><span>$${tot.toFixed(2)}</span></div>
          <div class="pr-row"><span>Auth: ${(100000+Math.floor(Math.random()*900000))}</span><span>APPROVED</span></div>
          ${customerAdded ? `<hr class="pr-sep"><div class="pr-row"><span>Points earned</span><span>+${pts}</span></div><div class="pr-row"><span>Points balance</span><span>${(2432+pts).toLocaleString()}</span></div>` : ''}
          <div class="pr-barcode">
            <div class="pr-bars" id="prBars"></div>
            <div class="pr-bc-num">${lastOrderNum}-${now.toISOString().slice(2,10).replace(/-/g,'')}</div>

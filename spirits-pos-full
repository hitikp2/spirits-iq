/* ─── Receipt bottom actions ─── */
.rm-bottom{padding:12px 16px;border-top:1px solid var(–border);flex-shrink:0;display:flex;gap:8px}
.rm-btn{flex:1;padding:12px;border-radius:var(–r);border:1px solid var(–border);background:var(–surface);color:var(–text);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .15s}

<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Spirits IQ – POS</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:wght@600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --card: #12151c;
    --card-h: #181c26;
    --surface: #161a24;
    --input: #1a1e28;
    --border: #1e2330;
    --text: #f0f0f2;
    --t2: #7a7f8e;
    --t3: #4a4f5e;
    --amber: #e5a526;
    --amber-g: rgba(229,165,38,0.15);
    --amber-s: rgba(229,165,38,0.08);
    --green: #34c759;
    --green-s: rgba(52,199,89,0.1);
    --red: #ff453a;
    --red-s: rgba(255,69,58,0.1);
    --blue: #5a9cf5;
    --blue-s: rgba(90,156,245,0.08);
    --r: 12px;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased}

/* ─── APP SHELL ─── */
.app{display:flex;flex-direction:column;height:100dvh;height:100vh}

/* ─── HEADER ─── */
.header{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;flex-shrink:0;background:var(–bg);border-bottom:1px solid var(–border);height:44px}
.logo-g{display:flex;align-items:center;gap:7px}
.logo-i{width:26px;height:26px;background:var(–amber);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px}
.logo-t{font-family:‘Playfair Display’,serif;font-size:15px;font-weight:700;letter-spacing:1px}
.logo-b{font-size:8px;font-weight:600;color:var(–t3);letter-spacing:1.5px}
.h-actions{display:flex;align-items:center;gap:5px}
.status{display:flex;align-items:center;gap:4px;padding:3px 8px;border-radius:16px;background:var(–green-s);font-size:10px;font-weight:600;color:var(–green)}
.status-dot{width:5px;height:5px;border-radius:50%;background:var(–green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.h-btn{width:30px;height:30px;border-radius:8px;background:var(–surface);border:1px solid var(–border);color:var(–t2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;transition:all .15s}
.h-btn:active{transform:scale(.9)}

/* ─── MAIN ─── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}

/* Search */
.search{padding:6px 10px;flex-shrink:0;display:flex;gap:6px}
.search-wrap{flex:1;display:flex;align-items:center;gap:7px;background:var(–input);border:1px solid var(–border);border-radius:var(–r);padding:0 10px;height:38px;transition:border-color .2s}
.search-wrap:focus-within{border-color:var(–amber);box-shadow:0 0 0 2px var(–amber-g)}
.s-icon{color:var(–t3);font-size:14px;flex-shrink:0}
.s-input{flex:1;background:0;border:0;outline:0;color:var(–text);font-size:13px;font-family:inherit}
.s-input::placeholder{color:var(–t3)}
.scan-btn{width:38px;height:38px;border-radius:var(–r);background:var(–amber-s);border:1px solid rgba(229,165,38,.2);color:var(–amber);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;flex-shrink:0;transition:all .15s}
.scan-btn:active{background:var(–amber);color:#000;transform:scale(.92)}

/* Filters */
.filters{display:flex;gap:5px;padding:0 10px 6px;overflow-x:auto;flex-shrink:0;scrollbar-width:none}
.filters::-webkit-scrollbar{display:none}
.chip{display:flex;align-items:center;gap:4px;padding:5px 12px;border-radius:18px;background:var(–surface);border:1px solid var(–border);color:var(–t2);font-size:11px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .15s;user-select:none}
.chip:active{transform:scale(.95)}
.chip.on{background:var(–amber);border-color:var(–amber);color:#000;font-weight:700}
.chip .em{font-size:12px}

/* Products */
.prods{flex:1;overflow-y:auto;overflow-x:hidden;padding:3px 10px 6px;min-height:0;-webkit-overflow-scrolling:touch}
.prods::-webkit-scrollbar{width:2px}
.prods::-webkit-scrollbar-thumb{background:var(–border);border-radius:4px}
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:7px}
@media(min-width:420px){.grid{grid-template-columns:repeat(3,1fr)}}

.p-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:10px;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;gap:4px;position:relative;animation:fadeUp .25s ease backwards}
.p-card:active{transform:scale(.97);border-color:var(–amber);background:var(–card-h)}
.p-card.in-cart{border-color:var(–amber);box-shadow:0 0 0 1px var(–amber),0 0 12px var(–amber-g)}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.p-card:nth-child(1){animation-delay:0s}.p-card:nth-child(2){animation-delay:.02s}.p-card:nth-child(3){animation-delay:.04s}.p-card:nth-child(4){animation-delay:.06s}.p-card:nth-child(5){animation-delay:.08s}.p-card:nth-child(6){animation-delay:.1s}

.p-top{display:flex;justify-content:space-between;align-items:flex-start}
.p-name{font-size:12px;font-weight:700;line-height:1.2}
.p-stk{font-size:9px;font-weight:600;padding:2px 5px;border-radius:5px;flex-shrink:0;margin-left:4px}
.stk-ok{background:var(–green-s);color:var(–green)}
.stk-lo{background:var(–red-s);color:var(–red)}
.p-meta{font-size:10px;color:var(–t2);line-height:1.2}
.p-bot{display:flex;align-items:flex-end;justify-content:space-between;margin-top:auto}
.p-price{font-size:16px;font-weight:700;color:var(–amber)}
.p-price .c{font-size:11px;font-weight:600}
.p-add{width:26px;height:26px;border-radius:7px;background:var(–amber-s);border:1px solid rgba(229,165,38,.2);color:var(–amber);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:600;cursor:pointer;transition:all .15s}
.p-add:active{background:var(–amber);color:#000;transform:scale(.85)}

/* Cart badge on product */
.p-card .cart-badge{position:absolute;top:-4px;right:-4px;width:18px;height:18px;border-radius:50%;background:var(–amber);color:#000;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,.3);animation:popIn .2s cubic-bezier(.34,1.56,.64,1)}
@keyframes popIn{from{transform:scale(0)}to{transform:scale(1)}}

/* ─── CART PANEL ─── */
.cart{flex-shrink:0;background:var(–surface);border-top:1px solid var(–border);display:flex;flex-direction:column;transition:max-height .3s ease;max-height:48px;overflow:hidden}
.cart.has-items{max-height:240px}
.cart.expanded{max-height:55vh}

.c-head{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;cursor:pointer;user-select:none;height:44px;flex-shrink:0}
.c-title-g{display:flex;align-items:center;gap:7px}
.c-title{font-size:13px;font-weight:700}
.c-count{font-size:9px;font-weight:700;background:var(–card);color:var(–t3);min-width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:0 4px}
.c-count.has{background:var(–amber);color:#000}
.c-toggle{font-size:10px;color:var(–t3);display:flex;align-items:center;gap:3px}

.c-cust{display:flex;padding:0 14px 6px;gap:6px;flex-shrink:0}
.cust-btn{display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:8px;background:var(–blue-s);border:1px solid rgba(90,156,245,.12);color:var(–blue);font-size:10px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
.cust-btn:active{transform:scale(.95)}
.cust-btn.added{background:var(–green-s);border-color:rgba(52,199,89,.15);color:var(–green)}

.c-items{flex:1;overflow-y:auto;padding:0 14px;min-height:0;scrollbar-width:none}
.c-items::-webkit-scrollbar{display:none}

.c-empty{display:flex;flex-direction:column;align-items:center;padding:12px;gap:4px}
.c-empty-i{font-size:20px;opacity:.3}
.c-empty-t{font-size:11px;color:var(–t3)}

.c-item{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(–border);animation:slideR .2s ease}
@keyframes slideR{from{opacity:0;transform:translateX(-6px)}to{opacity:1;transform:translateX(0)}}
.ci-info{flex:1;min-width:0}
.ci-name{font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ci-det{font-size:9px;color:var(–t2)}
.qty-c{display:flex;align-items:center;border-radius:7px;overflow:hidden;border:1px solid var(–border);height:26px}
.qty-b{width:26px;height:26px;display:flex;align-items:center;justify-content:center;background:var(–card);border:0;color:var(–text);font-size:13px;cursor:pointer}
.qty-b:active{background:var(–card-h)}
.qty-b.mi{color:var(–red)}
.qty-v{width:24px;text-align:center;font-size:11px;font-weight:700;background:var(–input)}
.ci-price{font-size:12px;font-weight:700;color:var(–amber);min-width:50px;text-align:right}

/* Footer */
.c-foot{padding:8px 14px;border-top:1px solid var(–border);flex-shrink:0}
.t-row{display:flex;justify-content:space-between;font-size:10px;color:var(–t2);padding:1px 0}
.t-row.big{font-size:15px;font-weight:700;color:var(–text);padding:5px 0 6px}
.t-row.big .t-amt{color:var(–amber)}
.ck-btn{width:100%;height:42px;border-radius:var(–r);background:var(–amber);border:0;color:#000;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:all .15s;letter-spacing:.3px}
.ck-btn:active{transform:scale(.97);filter:brightness(.9)}
.ck-btn:disabled{background:var(–card);color:var(–t3);cursor:not-allowed}

/* ─── BOTTOM NAV ─── */
.bnav{display:flex;align-items:center;justify-content:space-around;height:48px;flex-shrink:0;background:var(–card);border-top:1px solid var(–border);padding-bottom:env(safe-area-inset-bottom,0)}
.n-item{display:flex;flex-direction:column;align-items:center;gap:1px;cursor:pointer;padding:3px 6px;border-radius:6px;transition:all .15s;position:relative}
.n-item:active{transform:scale(.88)}
.n-i{font-size:16px;color:var(–t3);transition:color .15s}
.n-l{font-size:8px;font-weight:600;color:var(–t3);letter-spacing:.3px}
.n-item.on .n-i{color:var(–amber)}
.n-item.on .n-l{color:var(–amber)}
.n-item.on::after{content:’’;position:absolute;top:-1px;left:50%;transform:translateX(-50%);width:16px;height:2px;background:var(–amber);border-radius:2px}

/* ═══════════════════════════════════════
MODAL OVERLAY SYSTEM
═══════════════════════════════════════ */
.overlay{position:fixed;inset:0;z-index:1000;display:none;flex-direction:column;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.overlay.show{display:flex}

/* Scanner modal */
.scanner-modal{position:fixed;inset:0;z-index:1000;display:none;flex-direction:column;background:#000}
.scanner-modal.show{display:flex}

.sc-viewport{flex:1;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.sc-cam{position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(30,35,48,.2) 0%,rgba(0,0,0,.8) 100%)}
.sc-bottle{font-size:72px;opacity:.1;animation:bob 3s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.sc-over{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.sc-topbar{position:absolute;top:12px;left:12px;right:12px;display:flex;justify-content:space-between;align-items:center}
.sc-close,.sc-flash{width:38px;height:38px;border-radius:50%;background:rgba(0,0,0,.5);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);color:#fff;font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.sc-close:active,.sc-flash:active{transform:scale(.9)}
.sc-frame{width:240px;height:150px;position:relative}
.sc-c{position:absolute;width:26px;height:26px;border-color:var(–amber);border-style:solid;border-width:0}
.sc-c.tl{top:0;left:0;border-top-width:3px;border-left-width:3px;border-top-left-radius:8px}
.sc-c.tr{top:0;right:0;border-top-width:3px;border-right-width:3px;border-top-right-radius:8px}
.sc-c.bl{bottom:0;left:0;border-bottom-width:3px;border-left-width:3px;border-bottom-left-radius:8px}
.sc-c.br{bottom:0;right:0;border-bottom-width:3px;border-right-width:3px;border-bottom-right-radius:8px}
.sc-line{position:absolute;top:50%;left:8px;right:8px;height:2px;background:var(–amber);box-shadow:0 0 12px var(–amber),0 0 30px rgba(229,165,38,.3);border-radius:2px;animation:scanLine 2s ease-in-out infinite}
@keyframes scanLine{0%,100%{top:12%;opacity:.6}50%{top:88%;opacity:1}}
.sc-hint{margin-top:20px;font-size:13px;font-weight:600;color:rgba(255,255,255,.6);text-shadow:0 1px 4px rgba(0,0,0,.5)}

.sc-result{position:absolute;bottom:0;left:0;right:0;background:var(–surface);border-top-left-radius:20px;border-top-right-radius:20px;padding:20px;transform:translateY(100%);transition:transform .35s cubic-bezier(.34,1.56,.64,1);border-top:1px solid var(–border)}
.sc-result.show{transform:translateY(0)}
.sr-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.sr-badge{font-size:9px;font-weight:700;padding:3px 8px;border-radius:5px;background:var(–green-s);color:var(–green);letter-spacing:.5px}
.sr-upc{font-family:‘DM Mono’,monospace;font-size:10px;color:var(–t3)}
.sr-prod{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.sr-name{font-size:15px;font-weight:700}
.sr-meta{font-size:11px;color:var(–t2);margin-top:2px}
.sr-price{font-size:20px;font-weight:700;color:var(–amber)}
.sr-add{width:100%;padding:13px;border-radius:var(–r);background:var(–amber);border:0;color:#000;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:all .15s}
.sr-add:active{transform:scale(.97)}
.sr-add.done{background:var(–green)}

/* ─── CHECKOUT MODAL ─── */
.checkout-modal .modal-content{position:absolute;bottom:0;left:0;right:0;max-height:92vh;background:var(–surface);border-top-left-radius:20px;border-top-right-radius:20px;display:flex;flex-direction:column;overflow:hidden;animation:slideUpModal .35s cubic-bezier(.34,1.56,.64,1)}
@keyframes slideUpModal{from{transform:translateY(100%)}to{transform:translateY(0)}}

.cm-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 12px;flex-shrink:0}
.cm-title{font-size:16px;font-weight:700}
.cm-close{width:30px;height:30px;border-radius:50%;background:var(–card);border:1px solid var(–border);color:var(–t2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px}
.cm-close:active{transform:scale(.9)}

.cm-body{flex:1;overflow-y:auto;padding:0 20px 20px}

/* Payment methods */
.pay-methods{display:flex;gap:8px;margin-bottom:16px}
.pay-m{flex:1;padding:14px 8px;border-radius:var(–r);background:var(–card);border:1.5px solid var(–border);text-align:center;cursor:pointer;transition:all .15s}
.pay-m:active{transform:scale(.95)}
.pay-m.sel{border-color:var(–amber);background:var(–amber-g)}
.pay-m-i{font-size:22px;margin-bottom:4px}
.pay-m-l{font-size:10px;font-weight:600;color:var(–t2)}
.pay-m.sel .pay-m-l{color:var(–amber)}

/* Checkout summary items */
.cm-items{margin-bottom:16px}
.cm-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(–border)}
.cm-i-left{display:flex;align-items:center;gap:8px}
.cm-i-qty{font-size:10px;font-weight:700;color:var(–amber);background:var(–amber-g);width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center}
.cm-i-name{font-size:12px;font-weight:600}
.cm-i-meta{font-size:10px;color:var(–t2)}
.cm-i-price{font-size:12px;font-weight:700}

.cm-totals{margin-bottom:16px}
.cm-t-row{display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:var(–t2)}
.cm-t-row.total{font-size:18px;font-weight:700;color:var(–text);padding:8px 0}
.cm-t-row.total .cm-t-v{color:var(–amber)}

/* Customer section in checkout */
.cm-customer{padding:12px;background:var(–card);border-radius:var(–r);border:1px solid var(–border);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.cm-cust-avatar{width:36px;height:36px;border-radius:50%;background:var(–blue-s);display:flex;align-items:center;justify-content:center;font-size:16px}
.cm-cust-info{flex:1}
.cm-cust-name{font-size:13px;font-weight:600}
.cm-cust-pts{font-size:10px;color:var(–t2)}
.cm-cust-earn{font-size:10px;color:var(–amber);font-weight:600}

.cm-charge{width:100%;padding:16px;border-radius:var(–r);background:var(–amber);border:0;color:#000;font-size:16px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s}
.cm-charge:active{transform:scale(.97);filter:brightness(.9)}

/* ─── RECEIPT MODAL ─── */
.receipt-modal .modal-content{position:absolute;inset:0;background:var(–bg);display:flex;flex-direction:column;overflow:hidden;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

.rm-head{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;flex-shrink:0;border-bottom:1px solid var(–border)}
.rm-tabs{display:flex;gap:4px}
.rm-tab{padding:6px 14px;border-radius:8px;font-size:11px;font-weight:600;color:var(–t3);cursor:pointer;transition:all .15s;background:var(–surface);border:1px solid var(–border)}
.rm-tab.on{background:var(–amber-g);border-color:var(–amber);color:var(–amber)}
.rm-tab:active{transform:scale(.95)}
.rm-close{width:30px;height:30px;border-radius:50%;background:var(–card);border:1px solid var(–border);color:var(–t2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px}
.rm-close:active{transform:scale(.9)}

.rm-body{flex:1;overflow-y:auto;padding:16px;-webkit-overflow-scrolling:touch}

/* Digital Receipt */
.d-receipt{background:linear-gradient(145deg,#141820,#0e1118);border:1px solid var(–border);border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,.4)}
.dr-head{background:linear-gradient(135deg,var(–amber),#c7891c);padding:24px 20px 20px;text-align:center;position:relative;overflow:hidden}
.dr-head::before{content:’’;position:absolute;top:-30px;right:-30px;width:90px;height:90px;background:rgba(255,255,255,.07);border-radius:50%}
.dr-logo{font-family:‘Playfair Display’,serif;font-size:18px;font-weight:700;color:#000;letter-spacing:2px}
.dr-sub{font-size:9px;font-weight:600;letter-spacing:3px;color:rgba(0,0,0,.45);margin-top:2px}
.dr-check{width:44px;height:44px;background:rgba(0,0,0,.13);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:14px auto 6px;font-size:22px;animation:scaleIn .4s cubic-bezier(.34,1.56,.64,1) .2s backwards}
@keyframes scaleIn{from{transform:scale(0)}to{transform:scale(1)}}
.dr-status{font-size:15px;font-weight:700;color:#000}
.dr-body{padding:18px 20px}
.dr-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.dr-lbl{font-size:9px;font-weight:600;color:var(–t3);letter-spacing:1px;text-transform:uppercase}
.dr-val{font-size:12px;font-weight:600;margin-top:1px}
.dr-sep{height:1px;background:var(–border);margin:14px 0}
.dr-sep.dash{background:0;border-top:1px dashed var(–border)}
.dr-ih{display:flex;justify-content:space-between;font-size:9px;font-weight:600;color:var(–t3);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px}
.dr-item{display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.02)}
.dr-il{display:flex;gap:8px;align-items:flex-start}
.dr-iq{font-size:10px;font-weight:700;color:var(–amber);background:var(–amber-g);width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.dr-in{font-size:12px;font-weight:600}
.dr-im{font-size:10px;color:var(–t2)}

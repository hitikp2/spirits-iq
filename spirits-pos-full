/* Printed Receipt */
.p-receipt-wrap{display:flex;flex-direction:column;align-items:center;padding:12px 0}
.p-receipt{width:280px;background:#faf9f5;color:#1a1a1a;font-family:‘DM Mono’,‘Courier New’,monospace;padding:18px 14px;position:relative;box-shadow:0 4px 20px rgba(0,0,0,.3)}
.p-receipt::before{content:’’;position:absolute;top:-6px;left:0;right:0;height:6px;background:linear-gradient(135deg,transparent 33.33%,#faf9f5 33.33%,#faf9f5 66.67%,transparent 66.67%),linear-gradient(225deg,transparent 33.33%,#faf9f5 33.33%,#faf9f5 66.67%,transparent 66.67%);background-size:12px 6px}
.p-receipt::after{content:’’;position:absolute;bottom:-6px;left:0;right:0;height:6px;background:linear-gradient(45deg,transparent 33.33%,#faf9f5 33.33%,#faf9f5 66.67%,transparent 66.67%),linear-gradient(315deg,transparent 33.33%,#faf9f5 33.33%,#faf9f5 66.67%,transparent 66.67%);background-size:12px 6px}

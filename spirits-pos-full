<script>
const TAX = 0.0975;
const products = [
  {id:1,name:"Don Julio 1942",brand:"Don Julio",size:"750ml",price:164.99,stock:3,cat:"tequila",upc:"0 88076 17495 3"},
  {id:2,name:"EH Taylor Small Batch",brand:"EH Taylor",size:"750ml",price:41.99,stock:11,cat:"bourbon",upc:"0 88004 12753 1"},
  {id:3,name:"Blanton's Single Barrel",brand:"Blanton's",size:"750ml",price:64.99,stock:5,cat:"bourbon",upc:"0 88004 02751 0"},
  {id:4,name:"Buffalo Trace",brand:"Buffalo Trace",size:"750ml",price:24.99,stock:24,cat:"bourbon",upc:"0 88004 01639 2"},
  {id:5,name:"Clase Azul Reposado",brand:"Clase Azul",size:"750ml",price:169.99,stock:2,cat:"tequila",upc:"7 50741 00102 5"},
  {id:6,name:"Casamigos Blanco",brand:"Casamigos",size:"750ml",price:44.99,stock:18,cat:"tequila",upc:"0 85592 10030 0"},
  {id:7,name:"Maker's Mark",brand:"Maker's Mark",size:"750ml",price:28.99,stock:30,cat:"bourbon",upc:"0 85246 13901 5"},
  {id:8,name:"Woodford Reserve",brand:"Woodford",size:"750ml",price:34.99,stock:14,cat:"bourbon",upc:"0 81128 00502 1"},
  {id:9,name:"Grey Goose",brand:"Grey Goose",size:"750ml",price:29.99,stock:20,cat:"vodka",upc:"0 80480 30015 3"},
  {id:10,name:"Fever-Tree Tonic",brand:"Fever-Tree",size:"500ml",price:5.99,stock:48,cat:"mixers",upc:"5 06041 04007 6"},
  {id:11,name:"Macallan 12yr",brand:"Macallan",size:"750ml",price:64.99,stock:7,cat:"whiskey",upc:"0 89540 53108 5"},
  {id:12,name:"Johnnie Walker Blue",brand:"Johnnie Walker",size:"750ml",price:189.99,stock:4,cat:"whiskey",upc:"0 88110 10037 9"},
];

let cart = {}, filter = 'all', cartExp = false, customerAdded = false, payMethod = 'card';
let lastOrderItems = [], lastOrderTotal = 0, lastOrderNum = '';
let scanProductId = 1;

// ─── PRODUCTS ───
function renderProducts() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const f = products.filter(p => {
    return (filter === 'all' || p.cat === filter) && (!q || p.name.toLowerCase().includes(q) || p.brand.toLowerCase().includes(q) || p.upc.replace(/ /g,'').includes(q.replace(/ /g,'')));
  });
  document.getElementById('prodsGrid').innerHTML = f.map(p => {
    const ic = cart[p.id], sc = p.stock <= 5 ? 'stk-lo' : 'stk-ok', pp = p.price.toFixed(2).split('.');
    return `<div class="p-card ${ic?'in-cart':''}" onclick="addToCart(${p.id})" id="c${p.id}">
      ${ic?`<div class="cart-badge">${ic.qty}</div>`:''}
      <div class="p-top"><span class="p-name">${p.name}</span><span class="p-stk ${sc}">${p.stock}</span></div>
      <div class="p-meta">${p.brand} · ${p.size}</div>
      <div class="p-bot"><span class="p-price">$${pp[0]}<span class="c">.${pp[1]}</span></span><div class="p-add" onclick="event.stopPropagation();addToCart(${p.id})">+</div></div>
    </div>`;
  }).join('');
}

function setFilter(c, el) {
  filter = c;
  document.querySelectorAll('.chip').forEach(x => x.classList.remove('on'));
  el.classList.add('on');
  renderProducts();
}

function addToCart(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  if (cart[id]) { if (cart[id].qty < p.stock) cart[id].qty++; }
  else cart[id] = { ...p, qty: 1 };
  const card = document.getElementById(`c${id}`);
  if (card) { card.classList.remove('bounce'); void card.offsetWidth; card.classList.add('bounce'); }
  updateCart(); renderProducts();
}

function changeQty(id, d) {
  if (!cart[id]) return;
  cart[id].qty += d;
  if (cart[id].qty <= 0) delete cart[id];
  updateCart(); renderProducts();
}

function updateCart() {
  const items = Object.values(cart), count = items.reduce((s,i) => s + i.qty, 0);
  const sub = items.reduce((s,i) => s + i.price * i.qty, 0), tx = sub * TAX, tot = sub + tx;
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartCount').className = 'c-count' + (count ? ' has' : '');
  document.getElementById('subtotal').textContent = '$' + sub.toFixed(2);
  document.getElementById('tax').textContent = '$' + tx.toFixed(2);
  document.getElementById('total').textContent = '$' + tot.toFixed(2);
  const btn = document.getElementById('ckBtn');
  btn.disabled = !count;
  btn.innerHTML = count ? `💳 Charge $${tot.toFixed(2)}` : '💳 Charge $0.00';

  // Cart panel auto-expand
  const panel = document.getElementById('cartPanel');
  panel.classList.toggle('has-items', count > 0);

  const el = document.getElementById('cartItems'), emp = document.getElementById('cartEmpty');
  el.querySelectorAll('.c-item').forEach(x => x.remove());
  if (!items.length) { emp.style.display = 'flex'; return; }
  emp.style.display = 'none';
  items.forEach(i => {
    const d = document.createElement('div'); d.className = 'c-item';
    d.innerHTML = `<div class="ci-info"><div class="ci-name">${i.name}</div><div class="ci-det">${i.brand} · ${i.size}</div></div>
      <div class="qty-c"><button class="qty-b mi" onclick="changeQty(${i.id},-1)">−</button><div class="qty-v">${i.qty}</div><button class="qty-b" onclick="changeQty(${i.id},1)">+</button></div>
      <div class="ci-price">$${(i.price*i.qty).toFixed(2)}</div>`;
    el.appendChild(d);
  });
}

function toggleCart() {
  cartExp = !cartExp;
  document.getElementById('cartPanel').classList.toggle('expanded', cartExp);
  document.getElementById('cartToggle').textContent = cartExp ? '▼' : '▲';
}

function toggleCustomer() {
  customerAdded = !customerAdded;
  const btn = document.getElementById('custBtn');
  if (customerAdded) { btn.textContent = '✓ James W. (2,432 pts)'; btn.className = 'cust-btn added'; }
  else { btn.textContent = '👤 Add Customer'; btn.className = 'cust-btn'; }
}

function navTo(el) {
  document.querySelectorAll('.n-item').forEach(n => n.classList.remove('on'));
  el.classList.add('on');
}

// ─── SCANNER ───
function openScanner() {
  document.getElementById('scannerModal').classList.add('show');
  document.getElementById('scanResult').classList.remove('show');
  // Simulate scan after delay
  setTimeout(() => simulateScan(), 1800);
}

function closeScanner() {
  document.getElementById('scannerModal').classList.remove('show');
}

function simulateScan() {
  // Pick a random product
  const p = products[Math.floor(Math.random() * products.length)];
  scanProductId = p.id;
  document.getElementById('scanUpc').textContent = 'UPC: ' + p.upc;
  document.getElementById('scanName').textContent = p.name;
  document.getElementById('scanMeta').textContent = `${p.brand} · ${p.size} · ${p.stock} in stock`;
  document.getElementById('scanPrice').textContent = '$' + p.price.toFixed(2);
  const btn = document.getElementById('scanAddBtn');
  btn.textContent = '＋ Add to Cart';
  btn.className = 'sr-add';
  document.getElementById('scanResult').classList.add('show');
}

function scanAddToCart() {
  addToCart(scanProductId);
  const btn = document.getElementById('scanAddBtn');
  btn.textContent = '✓ Added!';
  btn.className = 'sr-add done';
  setTimeout(() => {
    closeScanner();
    showToast('Item added to cart');
  }, 600);
}

// ─── CHECKOUT ───
function openCheckout() {
  if (!Object.keys(cart).length) return;
  const items = Object.values(cart);
  const sub = items.reduce((s,i) => s + i.price * i.qty, 0), tx = sub * TAX, tot = sub + tx;
  const pts = Math.round(tot);

  // Customer
  document.getElementById('cmCustomer').style.display = customerAdded ? 'flex' : 'none';
  document.getElementById('cmEarnPts').textContent = '+' + pts + ' pts';

  // Items
  document.getElementById('cmItems').innerHTML = items.map(i => `
    <div class="cm-item"><div class="cm-i-left"><span class="cm-i-qty">${i.qty}</span><div><div class="cm-i-name">${i.name}</div><div class="cm-i-meta">${i.brand} · ${i.size}</div></div></div><span class="cm-i-price">$${(i.price*i.qty).toFixed(2)}</span></div>
  `).join('');

  document.getElementById('cmSubtotal').textContent = '$' + sub.toFixed(2);
  document.getElementById('cmTax').textContent = '$' + tx.toFixed(2);
  document.getElementById('cmTotal').textContent = '$' + tot.toFixed(2);
  document.getElementById('cmCharge').innerHTML = `💳 Charge $${tot.toFixed(2)}`;

  document.getElementById('checkoutModal').classList.add('show');
}

function closeCheckout(e) {
  if (e && e.target !== document.getElementById('checkoutModal')) return;
  document.getElementById('checkoutModal').classList.remove('show');
}

function selectPay(el, method) {
  payMethod = method;
  document.querySelectorAll('.pay-m').forEach(x => x.classList.remove('sel'));
  el.classList.add('sel');
  const icons = { card: '💳', cash: '💵', tap: '📱' };
  const items = Object.values(cart);
  const tot = items.reduce((s,i) => s + i.price * i.qty, 0) * (1 + TAX);
  document.getElementById('cmCharge').innerHTML = `${icons[method]} Charge $${tot.toFixed(2)}`;
}

function processPayment() {
  const items = Object.values(cart);
  const sub = items.reduce((s,i) => s + i.price * i.qty, 0), tot = sub * (1 + TAX);

  // Store order info
  lastOrderItems = items.map(i => ({...i}));
  lastOrderTotal = tot;
  lastOrderNum = 'SIQ-' + (1000 + Math.floor(Math.random() * 9000));

  // Close checkout, open receipt
  document.getElementById('checkoutModal').classList.remove('show');
  cart = {};
  updateCart();
  renderProducts();

  setTimeout(() => openReceipt(), 300);
}

// ─── RECEIPT ───
let receiptView = 'digital';

function openReceipt() {
  receiptView = 'digital';
  document.querySelectorAll('.rm-tab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.rm-tab')[0].classList.add('on');
  renderReceipt();
  document.getElementById('receiptModal').classList.add('show');
}

function closeReceipt() {
  document.getElementById('receiptModal').classList.remove('show');
}

function switchReceipt(view, el) {
  receiptView = view;
  document.querySelectorAll('.rm-tab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  renderReceipt();
}

function renderReceipt() {
  const body = document.getElementById('rmBody');
  const items = lastOrderItems;
  const sub = items.reduce((s,i) => s + i.price * i.qty, 0);

## Feature 3: Offline Mode

### What It Does

When the internet connection drops, the POS continues to operate for cash-only sales using locally cached data. Transactions queue up and auto-sync when the connection is restored.

### Architecture Overview

```
┌─────────────────────────────────┐
│       SERVICE WORKER            │
│  Caches: app shell, fonts,     │
│  static assets                  │
├─────────────────────────────────┤
│       INDEXEDDB                 │
│  Tables:                        │
│  - products (full catalog)     │
│  - customers (phone + name)    │
│  - categories                   │
│  - storeConfig (tax rate, etc) │
│  - syncQueue (pending txns)    │
│  - localInventory (stock delta)│
└─────────────────────────────────┘
```

### What Needs Building

#### Step 1: Service Worker

**Create:** `public/sw.js`

```js
const CACHE_NAME = 'spirits-iq-v1';
const STATIC_ASSETS = [
  '/',
  '/pos',
  // Add key static assets
];

self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then(cache => cache.addAll(STATIC_ASSETS))
  );
});

self.addEventListener('fetch', (event) => {
  // Network-first for API calls, cache-first for static assets
  if (event.request.url.includes('/api/')) {
    event.respondWith(
      fetch(event.request)
        .catch(() => caches.match(event.request))
    );
  } else {
    event.respondWith(
      caches.match(event.request)
        .then(cached => cached || fetch(event.request))
    );
  }
});
```

**Register in:** `src/app/layout.tsx` or `src/app/providers.tsx`

```tsx
useEffect(() => {
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
  }
}, []);
```

#### Step 2: IndexedDB Data Layer

**Create:** `src/lib/offline/db.ts`

Use the `idb` npm package (lightweight IndexedDB wrapper):

```bash
npm install idb
```

```ts
import { openDB, DBSchema } from 'idb';

interface SpiritsDB extends DBSchema {
  products: {
    key: string;
    value: {
      id: string;
      name: string;
      brand: string;
      retailPrice: number;
      quantity: number; // local copy, decremented offline
      categoryId: string;
      category: { name: string; icon: string };
      sku: string;
      upc?: string;
      isAgeRestricted: boolean;
      size?: string;
    };
    indexes: { 'by-category': string; 'by-sku': string };
  };
  customers: {
    key: string;
    value: { id: string; firstName: string; lastName: string; phone: string; loyaltyTier: string; totalPoints: number };
    indexes: { 'by-phone': string };
  };
  syncQueue: {
    key: number;
    value: {
      id?: number;
      type: 'TRANSACTION' | 'STOCK_ADJUST' | 'CUSTOMER_UPDATE';
      data: any;
      status: 'PENDING' | 'SYNCING' | 'SYNCED' | 'FAILED';
      createdAt: string;
      attempts: number;
    };
  };
  storeConfig: {
    key: string;
    value: any;
  };
}

export async function getOfflineDB() {
  return openDB<SpiritsDB>('spirits-iq', 1, {
    upgrade(db) {
      const productStore = db.createObjectStore('products', { keyPath: 'id' });
      productStore.createIndex('by-category', 'categoryId');
      productStore.createIndex('by-sku', 'sku');

      const customerStore = db.createObjectStore('customers', { keyPath: 'id' });
      customerStore.createIndex('by-phone', 'phone');

      db.createObjectStore('syncQueue', { keyPath: 'id', autoIncrement: true });
      db.createObjectStore('storeConfig', { keyPath: 'key' });
    },
  });
}
```

#### Step 3: Data Sync Service

**Create:** `src/lib/offline/sync.ts`

```ts
import { getOfflineDB } from './db';

// Cache products from API to IndexedDB
export async function cacheProducts(products: Product[]) {
  const db = await getOfflineDB();
  const tx = db.transaction('products', 'readwrite');
  for (const product of products) {
    await tx.store.put(product);
  }
  await tx.done;
}

// Get products from IndexedDB (for offline use)
export async function getOfflineProducts() {
  const db = await getOfflineDB();
  return db.getAll('products');
}

// Queue a transaction for later sync
export async function queueTransaction(transactionData: any) {
  const db = await getOfflineDB();
  await db.add('syncQueue', {
    type: 'TRANSACTION',
    data: transactionData,
    status: 'PENDING',
    createdAt: new Date().toISOString(),
    attempts: 0,
  });
}

// Decrement local inventory
export async function decrementLocalStock(productId: string, qty: number) {
  const db = await getOfflineDB();
  const product = await db.get('products', productId);
  if (product) {
    product.quantity = Math.max(0, product.quantity - qty);
    await db.put('products', product);
  }
}

// Sync all pending items when back online
export async function syncPendingQueue() {
  const db = await getOfflineDB();
  const pending = await db.getAll('syncQueue');
  const toSync = pending.filter(item => item.status === 'PENDING');

  for (const item of toSync) {
    try {
      item.status = 'SYNCING';
      item.attempts += 1;
      await db.put('syncQueue', item);

      // POST to server
      const res = await fetch('/api/pos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(item.data),
      });

      if (res.ok) {
        item.status = 'SYNCED';
      } else {
        item.status = item.attempts >= 3 ? 'FAILED' : 'PENDING';
      }
      await db.put('syncQueue', item);
    } catch {
      item.status = 'PENDING';
      await db.put('syncQueue', item);
      break; // Stop syncing if network failed again
    }
  }

  return toSync.length;
}
```

#### Step 4: Offline-Aware Hook

**Create:** `src/hooks/useOffline.ts`

```ts
import { useState, useEffect, useCallback } from 'react';
import { cacheProducts, getOfflineProducts, syncPendingQueue } from '@/lib/offline/sync';

export function useOfflineStatus() {
  const [isOnline, setIsOnline] = useState(true);
  const [pendingCount, setPendingCount] = useState(0);
  const [syncing, setSyncing] = useState(false);

  useEffect(() => {
    const handleOnline = () => {
      setIsOnline(true);
      // Auto-sync when coming back online
      handleSync();
    };
    const handleOffline = () => setIsOnline(false);

    // Check initial state
    setIsOnline(navigator.onLine);

    window.addEventListener('online', handleOnline);
    window.addEventListener('offline', handleOffline);
    return () => {
      window.removeEventListener('online', handleOnline);
      window.removeEventListener('offline', handleOffline);
    };
  }, []);

  const handleSync = useCallback(async () => {
    setSyncing(true);
    try {
      const synced = await syncPendingQueue();
      setPendingCount(prev => Math.max(0, prev - synced));
    } finally {
      setSyncing(false);
    }
  }, []);

  return { isOnline, pendingCount, syncing, sync: handleSync, setPendingCount };
}
```

#### Step 5: Integrate into POS Page

Modify `src/app/(app)/pos/page.tsx`:

```tsx
const { isOnline, pendingCount, syncing, sync } = useOfflineStatus();

// Use offline data when not connected:
const products = isOnline 
  ? serverProducts     // from useInventory() React Query hook
  : offlineProducts;   // from IndexedDB

// When processing a sale offline:
async function handleOfflineSale() {
  // Queue transaction to IndexedDB
  await queueTransaction({
    storeId,
    cashierId: userId,
    items: cart.map(i => ({ ... })),
    paymentMethod: 'CASH',  // Only cash works offline
    offlineCreatedAt: new Date().toISOString(),
  });
  
  // Decrement local inventory
  for (const item of cart) {
    await decrementLocalStock(item.productId, item.quantity);
  }
  
  // Clear cart, show success
  setCart([]);
  showToast('Sale recorded offline — will sync when online');
}
```


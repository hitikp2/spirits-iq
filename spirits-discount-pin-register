<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Spirits IQ – Discounts · PIN Switch · Multi-Register</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0a0c10;--surface:#12151c;--card:#161a24;--input:#1a1e28;--border:#1e2330;--text:#f0f0f2;--t2:#7a7f8e;--t3:#4a4f5e;--amber:#e5a526;--amber-g:rgba(229,165,38,.15);--amber-s:rgba(229,165,38,.08);--green:#34c759;--green-s:rgba(52,199,89,.1);--red:#ff453a;--red-s:rgba(255,69,58,.1);--blue:#5a9cf5;--blue-s:rgba(90,156,245,.08);--purple:#a78bfa;--purple-s:rgba(167,139,250,.08);--r:12px}
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased}
  .shell{max-width:480px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column}
  .tabs{display:flex;gap:4px;padding:12px 14px;background:var(--bg);position:sticky;top:0;z-index:100;border-bottom:1px solid var(--border)}
  .tab{flex:1;padding:10px 4px;text-align:center;font-size:10px;font-weight:600;color:var(--t3);background:var(--surface);border:1px solid var(--border);border-radius:10px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;transition:all .2s}
  .tab:active{transform:scale(.96)}
  .tab.on{background:var(--amber-g);border-color:var(--amber);color:var(--amber)}
  .tab-i{font-size:18px}
  .panel{display:none;flex:1;padding:16px;animation:fadeIn .3s ease}
  .panel.on{display:block}
  @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
  .sec{font-size:10px;font-weight:700;color:var(--t3);letter-spacing:1.5px;text-transform:uppercase;margin:16px 0 10px}
  .sec:first-child{margin-top:0}
  .fcard{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:12px}
  .fcard-t{font-size:14px;font-weight:700;margin-bottom:4px}
  .fcard-d{font-size:12px;color:var(--t2);line-height:1.5}
  .btn{width:100%;padding:14px;border-radius:var(--r);border:0;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s}
  .btn:active{transform:scale(.97)}
  .btn-amber{background:var(--amber);color:#000}
  .btn-green{background:var(--green);color:#000}
  .btn-surface{background:var(--card);color:var(--text);border:1px solid var(--border)}
  .btn-red{background:var(--red-s);color:var(--red);border:1px solid rgba(255,69,58,.2)}
  .btn:disabled{opacity:.4;cursor:not-allowed}
  .btn-sm{padding:10px 14px;font-size:12px;width:auto}
  .btn-row{display:flex;gap:8px}
  .btn-row .btn{flex:1}
  .mono{font-family:'DM Mono',monospace}
  .toast{position:fixed;top:56px;left:50%;transform:translateX(-50%) translateY(-20px);padding:10px 18px;border-radius:var(--r);background:var(--green);color:#000;font-size:12px;font-weight:700;z-index:2000;opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;white-space:nowrap;box-shadow:0 8px 24px rgba(52,199,89,.3)}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ═══ DISCOUNT CODES ═══ */
.dc-input-row{display:flex;gap:8px;margin-bottom:12px}
.dc-input{flex:1;padding:12px 14px;border-radius:var(–r);background:var(–input);border:1px solid var(–border);color:var(–text);font-size:14px;font-family:‘DM Mono’,monospace;letter-spacing:2px;text-transform:uppercase;outline:0;transition:border-color .2s}
.dc-input:focus{border-color:var(–amber)}
.dc-input::placeholder{color:var(–t3);letter-spacing:1px;text-transform:none}
.dc-apply{padding:12px 20px;border-radius:var(–r);background:var(–amber);border:0;color:#000;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;flex-shrink:0;transition:all .15s}
.dc-apply:active{transform:scale(.95)}
.dc-apply:disabled{opacity:.4}

.dc-result{padding:14px;border-radius:var(–r);margin-bottom:12px;display:flex;align-items:center;gap:12px;animation:slideIn .3s ease}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.dc-result.valid{background:var(–green-s);border:1px solid rgba(52,199,89,.15)}
.dc-result.invalid{background:var(–red-s);border:1px solid rgba(255,69,58,.15)}
.dc-result.loyalty{background:var(–purple-s);border:1px solid rgba(167,139,250,.15)}
.dcr-icon{font-size:24px}
.dcr-info{flex:1}
.dcr-title{font-size:13px;font-weight:700}
.dcr-title.valid{color:var(–green)}
.dcr-title.invalid{color:var(–red)}
.dcr-title.loyalty{color:var(–purple)}
.dcr-sub{font-size:10px;color:var(–t2);margin-top:2px}
.dcr-remove{width:24px;height:24px;border-radius:50%;background:var(–card);border:1px solid var(–border);color:var(–t2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;flex-shrink:0}
.dcr-remove:active{transform:scale(.85)}

.dc-types{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.dc-type{padding:12px;border-radius:var(–r);background:var(–card);border:1px solid var(–border);text-align:center;cursor:pointer;transition:all .15s}
.dc-type:active{transform:scale(.96)}
.dc-type.active{border-color:var(–amber);background:var(–amber-g)}
.dc-type-i{font-size:20px;margin-bottom:4px}
.dc-type-l{font-size:10px;font-weight:600;color:var(–t2)}
.dc-type-v{font-size:14px;font-weight:700;margin-top:2px}

/* Cart preview */
.dc-cart{background:var(–surface);border:1px solid var(–border);border-radius:16px;overflow:hidden;margin-bottom:12px}
.dc-cart-head{padding:10px 14px;border-bottom:1px solid var(–border);display:flex;justify-content:space-between;font-size:11px;font-weight:600;color:var(–t3)}
.dc-cart-item{display:flex;justify-content:space-between;padding:8px 14px;border-bottom:1px solid rgba(255,255,255,.02);font-size:12px}
.dc-cart-item .name{font-weight:600}
.dc-cart-item .price{font-weight:700;color:var(–amber)}
.dc-cart-foot{padding:8px 14px}
.dc-row{display:flex;justify-content:space-between;padding:2px 0;font-size:11px;color:var(–t2)}
.dc-row.discount{color:var(–green);font-weight:600}
.dc-row.total{font-size:16px;font-weight:700;color:var(–text);padding:6px 0}
.dc-row.total .val{color:var(–amber)}
.dc-row .strikethrough{text-decoration:line-through;color:var(–t3);margin-right:6px}

/* ═══ PIN SWITCH ═══ */
.pin-current{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(–surface);border:1px solid var(–border);border-radius:16px;margin-bottom:12px}
.pin-avatar{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0}
.pin-info{flex:1}
.pin-name{font-size:14px;font-weight:700}
.pin-role{font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;display:inline-block;margin-top:2px}
.pin-time{font-size:10px;color:var(–t3);text-align:right}
.pin-time-val{font-size:12px;font-weight:600;color:var(–text)}

.pin-switch-btn{width:100%;padding:14px;border-radius:var(–r);background:var(–blue-s);border:1px solid rgba(90,156,245,.15);color:var(–blue);font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:16px;transition:all .15s}
.pin-switch-btn:active{transform:scale(.97)}

/* PIN pad */
.pin-pad-overlay{display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);align-items:center;justify-content:center}
.pin-pad-overlay.show{display:flex}
.pin-pad{background:var(–surface);border:1px solid var(–border);border-radius:20px;padding:24px;width:300px;text-align:center}
.pin-pad-title{font-size:16px;font-weight:700;margin-bottom:4px}
.pin-pad-sub{font-size:11px;color:var(–t2);margin-bottom:16px}
.pin-dots{display:flex;justify-content:center;gap:12px;margin-bottom:20px}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(–border);transition:all .15s}
.pin-dot.filled{border-color:var(–amber);background:var(–amber)}
.pin-dot.error{border-color:var(–red);background:var(–red);animation:shake .3s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-4px)}75%{transform:translateX(4px)}}
.pin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:220px;margin:0 auto}
.pin-key{height:52px;border-radius:var(–r);background:var(–card);border:1px solid var(–border);color:var(–text);font-size:22px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .1s;font-family:‘DM Sans’,sans-serif}
.pin-key:active{background:var(–amber);color:#000;transform:scale(.94)}
.pin-key.back{font-size:16px;color:var(–t2)}
.pin-key.empty{visibility:hidden}
.pin-cancel{margin-top:12px;font-size:12px;color:var(–t3);cursor:pointer;padding:8px}
.pin-cancel:active{color:var(–text)}

/* Quick switch badges */
.pin-quick{display:flex;gap:8px;margin-bottom:16px;overflow-x:auto;scrollbar-width:none}
.pin-quick::-webkit-scrollbar{display:none}
.pin-q{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;min-width:64px;padding:10px 8px;border-radius:var(–r);background:var(–card);border:1px solid var(–border);transition:all .15s}
.pin-q:active{transform:scale(.95);border-color:var(–amber)}
.pin-q-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}
.pin-q-name{font-size:9px;font-weight:600;color:var(–t2);white-space:nowrap}
.pin-q-status{width:6px;height:6px;border-radius:50%}

/* ═══ MULTI-REGISTER ═══ */
.reg-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.reg-card{padding:14px;border-radius:16px;background:var(–surface);border:1px solid var(–border);cursor:pointer;transition:all .15s;position:relative}
.reg-card:active{transform:scale(.97)}
.reg-card.active{border-color:var(–green);box-shadow:0 0 0 1px var(–green),0 0 12px var(–green-s)}
.reg-card.idle{border-color:var(–border);opacity:.7}
.reg-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.reg-name{font-size:13px;font-weight:700}
.reg-status{font-size:8px;font-weight:700;padding:3px 6px;border-radius:4px;letter-spacing:.5px}
.reg-status.on{background:var(–green-s);color:var(–green)}
.reg-status.off{background:var(–card);color:var(–t3)}
.reg-cashier{font-size:10px;color:var(–t2);margin-bottom:6px}
.reg-stats{display:flex;gap:8px}
.reg-stat{font-size:9px;color:var(–t3)}
.reg-stat span{color:var(–text);font-weight:600}

.sync-indicator{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(–r);background:var(–surface);border:1px solid var(–border);margin-bottom:12px;font-size:11px;color:var(–t2)}
.sync-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sync-dot.live{background:var(–green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

.event-feed{background:var(–surface);border:1px solid var(–border);border-radius:16px;overflow:hidden;margin-bottom:12px}
.ef-head{padding:10px 14px;border-bottom:1px solid var(–border);font-size:12px;font-weight:700}
.ef-item{display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid var(–border);font-size:11px}
.ef-item:last-child{border-bottom:0}
.ef-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.ef-info{flex:1;min-width:0}
.ef-title{font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ef-meta{font-size:9px;color:var(–t3)}
.ef-time{font-size:9px;color:var(–t3);flex-shrink:0}
</style>

</head>

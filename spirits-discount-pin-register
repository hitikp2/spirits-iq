<script>
function switchTab(n,el){document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));el.classList.add('on');document.getElementById('panel-'+n).classList.add('on')}
function showToast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200)}

// ═══ DISCOUNT CODES ═══
const CODES={
  'SUMMER15':{type:'percent',value:15,label:'Summer Sale — 15% off',icon:'🌞'},
  'SAVE20':{type:'fixed',value:20,label:'$20 off your order',icon:'🏷️'},
  'SIQ-VK4NX82R':{type:'loyalty',value:25,label:'Loyalty Reward — $25 off (500 pts)',icon:'⭐'},
  'BOGO-TONIC':{type:'bogo',value:5.99,label:'BOGO Fever-Tree Tonic — 1 free',icon:'🎁'},
  'WELCOME10':{type:'percent',value:10,label:'New Customer — 10% off',icon:'👋'},
};
let activeDiscount=null;
const SUBTOTAL=218.96;
const TAX_RATE=0.0975;

function demoCode(code){document.getElementById('dcInput').value=code;applyCode()}

function applyCode(){
  const input=document.getElementById('dcInput');
  const code=input.value.trim().toUpperCase();
  const el=document.getElementById('dcResult');
  if(!code){el.innerHTML='';return}
  const disc=CODES[code];
  if(!disc){
    el.innerHTML=`<div class="dc-result invalid"><span class="dcr-icon">❌</span><div class="dcr-info"><div class="dcr-title invalid">Invalid Code</div><div class="dcr-sub">"${code}" not found or expired</div></div></div>`;
    activeDiscount=null;updateCartPreview();return;
  }
  const cls=disc.type==='loyalty'?'loyalty':'valid';
  el.innerHTML=`<div class="dc-result ${cls}"><span class="dcr-icon">${disc.icon}</span><div class="dcr-info"><div class="dcr-title ${cls}">${disc.label}</div><div class="dcr-sub">Code: ${code}</div></div><div class="dcr-remove" onclick="removeDiscount()">✕</div></div>`;
  activeDiscount=disc;
  updateCartPreview();
}

function removeDiscount(){
  document.getElementById('dcResult').innerHTML='';
  document.getElementById('dcInput').value='';
  activeDiscount=null;
  updateCartPreview();
}

function updateCartPreview(){
  const foot=document.getElementById('dcCartFoot');
  let discount=0;
  if(activeDiscount){
    if(activeDiscount.type==='percent')discount=SUBTOTAL*(activeDiscount.value/100);
    else if(activeDiscount.type==='fixed')discount=activeDiscount.value;
    else if(activeDiscount.type==='loyalty')discount=activeDiscount.value;
    else if(activeDiscount.type==='bogo')discount=activeDiscount.value;
    discount=Math.min(discount,SUBTOTAL);
  }
  const afterDiscount=SUBTOTAL-discount;
  const tax=afterDiscount*TAX_RATE;
  const total=afterDiscount+tax;
  foot.innerHTML=`
    <div class="dc-row"><span>Subtotal</span><span>$${SUBTOTAL.toFixed(2)}</span></div>
    ${discount>0?`<div class="dc-row discount"><span>Discount</span><span>−$${discount.toFixed(2)}</span></div>`:''}
    <div class="dc-row"><span>Tax (9.75%)</span><span>$${tax.toFixed(2)}</span></div>
    <div class="dc-row total"><span>Total</span><span class="val">${discount>0?`<span class="strikethrough">$${(SUBTOTAL*(1+TAX_RATE)).toFixed(2)}</span>`:''} $${total.toFixed(2)}</span></div>`;
}

// ═══ PIN SWITCH ═══
let pinValue='';
const EMPLOYEES={
  '0000':{name:'Sam Torres',initials:'ST',role:'CASHIER',color:'var(--green)',colorBg:'var(--green-s)'},
  '1234':{name:'Alex Rivera',initials:'AR',role:'OWNER',color:'var(--amber)',colorBg:'var(--amber-g)'},
  '5678':{name:'Jordan Chen',initials:'JC',role:'MANAGER',color:'var(--purple)',colorBg:'var(--purple-s)'},
};

function openPinPad(){
  pinValue='';
  updatePinDots();
  document.getElementById('pinPadOverlay').classList.add('show');
}

function closePinPad(){document.getElementById('pinPadOverlay').classList.remove('show')}

function pinInput(d){
  if(pinValue.length>=4)return;
  pinValue+=d;
  updatePinDots();
  if(pinValue.length===4)setTimeout(()=>validatePin(),200);
}

function pinBack(){pinValue=pinValue.slice(0,-1);updatePinDots()}

function updatePinDots(){
  const dots=document.querySelectorAll('#pinDots .pin-dot');
  dots.forEach((d,i)=>{d.className='pin-dot'+(i<pinValue.length?' filled':'')});
}

function validatePin(){
  const emp=EMPLOYEES[pinValue];
  if(emp){
    switchCashier(emp);
    closePinPad();
  }else{
    const dots=document.querySelectorAll('#pinDots .pin-dot');
    dots.forEach(d=>d.className='pin-dot error');
    setTimeout(()=>{pinValue='';updatePinDots()},500);
    showToast('Invalid PIN — try again');
  }
}

function quickSwitch(name,role,initials,color){openPinPad()}

function switchCashier(emp){
  const el=document.getElementById('pinCurrent');
  el.innerHTML=`
    <div class="pin-avatar" style="background:${emp.colorBg};color:${emp.color}">${emp.initials}</div>
    <div class="pin-info"><div class="pin-name">${emp.name}</div><div class="pin-role" style="background:${emp.colorBg};color:${emp.color}">${emp.role}</div></div>
    <div class="pin-time"><div style="font-size:9px;color:var(--t3)">Shift</div><div class="pin-time-val">0h 0m</div></div>`;
  showToast(`Switched to ${emp.name}`);
}

// ═══ MULTI-REGISTER ═══
const EVENTS=[
  {icon:'💳',bg:'var(--green-s)',title:'Sale #0053 — $44.99',meta:'Register 2 · Jordan Chen · Casamigos Blanco'},
  {icon:'📦',bg:'var(--amber-g)',title:'Low stock alert: Clase Azul → 1 unit',meta:'Auto-triggered by Register 1 sale'},
  {icon:'🔔',bg:'var(--red-s)',title:'Age verification required on Register 2',meta:'Don Julio 1942 added to cart'},
  {icon:'💰',bg:'var(--green-s)',title:'Sale #0054 — $29.99',meta:'iPad Floor · Alex Rivera · Grey Goose'},
  {icon:'⭐',bg:'var(--purple-s)',title:'VIP customer checked in: James W.',meta:'Register 1 · Phone lookup'},
];
let eventIdx=0;

function simulateEvent(){
  const e=EVENTS[eventIdx%EVENTS.length];
  eventIdx++;
  const feed=document.getElementById('eventFeed');
  const items=feed.querySelectorAll('.ef-item');
  const div=document.createElement('div');
  div.className='ef-item';
  div.style.animation='slideIn .3s ease';
  div.innerHTML=`<div class="ef-icon" style="background:${e.bg}">${e.icon}</div><div class="ef-info"><div class="ef-title">${e.title}</div><div class="ef-meta">${e.meta}</div></div><div class="ef-time">Just now</div>`;
  feed.insertBefore(div,items[0]);
  if(feed.querySelectorAll('.ef-item').length>6)feed.querySelectorAll('.ef-item')[6].remove();
  showToast('Event synced across all registers');
}
</script>


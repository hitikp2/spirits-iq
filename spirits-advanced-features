<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Spirits IQ – Advanced Features</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0c10;--surface:#12151c;--card:#161a24;--input:#1a1e28;--border:#1e2330;
    --text:#f0f0f2;--t2:#7a7f8e;--t3:#4a4f5e;
    --amber:#e5a526;--amber-g:rgba(229,165,38,.15);--amber-s:rgba(229,165,38,.08);
    --green:#34c759;--green-s:rgba(52,199,89,.1);
    --red:#ff453a;--red-s:rgba(255,69,58,.1);
    --blue:#5a9cf5;--blue-s:rgba(90,156,245,.08);
    --purple:#a78bfa;--purple-s:rgba(167,139,250,.08);
    --r:12px;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased}

.shell{max-width:480px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column}

/* Tabs */
.tabs{display:flex;gap:4px;padding:12px 14px;background:var(–bg);position:sticky;top:0;z-index:100;border-bottom:1px solid var(–border)}
.tab{flex:1;padding:10px 6px;text-align:center;font-size:11px;font-weight:600;color:var(–t3);background:var(–surface);border:1px solid var(–border);border-radius:10px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;transition:all .2s}
.tab:active{transform:scale(.96)}
.tab.on{background:var(–amber-g);border-color:var(–amber);color:var(–amber)}
.tab-i{font-size:18px}

.panel{display:none;flex:1;padding:16px;animation:fadeIn .3s ease}
.panel.on{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* Section labels */
.sec{font-size:10px;font-weight:700;color:var(–t3);letter-spacing:1.5px;text-transform:uppercase;margin:16px 0 10px}
.sec:first-child{margin-top:0}

/* Cards */
.fcard{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:16px;margin-bottom:12px}
.fcard-t{font-size:14px;font-weight:700;margin-bottom:4px}
.fcard-d{font-size:12px;color:var(–t2);line-height:1.5}

/* Buttons */
.btn{width:100%;padding:14px;border-radius:var(–r);border:0;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s}
.btn:active{transform:scale(.97)}
.btn-amber{background:var(–amber);color:#000}
.btn-green{background:var(–green);color:#000}
.btn-surface{background:var(–card);color:var(–text);border:1px solid var(–border)}
.btn-red{background:var(–red-s);color:var(–red);border:1px solid rgba(255,69,58,.2)}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-sm{padding:10px 14px;font-size:12px;width:auto}
.btn-row{display:flex;gap:8px}
.btn-row .btn{flex:1}

/* ═══════════════════════════════════════
1. AGE VERIFICATION
═══════════════════════════════════════ */
.av-trigger{background:linear-gradient(135deg,rgba(255,69,58,.08),rgba(255,69,58,.02));border:1px solid rgba(255,69,58,.15);border-radius:16px;padding:16px;margin-bottom:12px;position:relative;overflow:hidden}
.av-trigger::before{content:’’;position:absolute;top:0;right:0;width:80px;height:80px;background:radial-gradient(circle,rgba(255,69,58,.06) 0%,transparent 70%)}
.av-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:6px;background:var(–red-s);font-size:9px;font-weight:700;color:var(–red);letter-spacing:.5px;margin-bottom:8px}
.av-title{font-size:15px;font-weight:700;margin-bottom:4px}
.av-desc{font-size:11px;color:var(–t2);line-height:1.5}

/* Age gate modal */
.age-gate{background:var(–surface);border-radius:20px;border:1px solid var(–border);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.ag-header{background:linear-gradient(135deg,#2a1a1a,#1a0a0a);padding:24px 20px;text-align:center;border-bottom:1px solid rgba(255,69,58,.15)}
.ag-icon{font-size:48px;margin-bottom:8px}
.ag-title{font-size:18px;font-weight:700}
.ag-sub{font-size:11px;color:var(–t2);margin-top:4px}
.ag-body{padding:20px}

.ag-methods{display:flex;gap:8px;margin-bottom:16px}
.ag-method{flex:1;padding:14px 8px;border-radius:var(–r);background:var(–card);border:1.5px solid var(–border);text-align:center;cursor:pointer;transition:all .15s}
.ag-method:active{transform:scale(.95)}
.ag-method.sel{border-color:var(–amber);background:var(–amber-g)}
.ag-m-i{font-size:24px;margin-bottom:4px}
.ag-m-l{font-size:10px;font-weight:600;color:var(–t2)}
.ag-method.sel .ag-m-l{color:var(–amber)}

/* DOB entry */
.dob-row{display:flex;gap:8px;margin-bottom:16px}
.dob-input{flex:1;padding:12px;border-radius:var(–r);background:var(–input);border:1px solid var(–border);color:var(–text);font-size:16px;font-family:‘DM Mono’,monospace;text-align:center;outline:0;transition:border-color .2s}
.dob-input:focus{border-color:var(–amber)}
.dob-input::placeholder{color:var(–t3)}

/* ID scan simulation */
.id-scan-area{border:2px dashed var(–border);border-radius:16px;padding:32px 16px;text-align:center;margin-bottom:16px;transition:all .3s}
.id-scan-area.scanning{border-color:var(–amber);background:var(–amber-s)}
.id-scan-area.verified{border-color:var(–green);background:var(–green-s)}
.id-scan-icon{font-size:36px;margin-bottom:8px}
.id-scan-text{font-size:12px;color:var(–t2);font-weight:500}

/* Verification result */
.av-result{padding:16px;border-radius:var(–r);margin-bottom:16px;display:flex;align-items:center;gap:12px}
.av-result.pass{background:var(–green-s);border:1px solid rgba(52,199,89,.15)}
.av-result.fail{background:var(–red-s);border:1px solid rgba(255,69,58,.15)}
.avr-icon{font-size:28px}
.avr-text{font-size:13px;font-weight:600}
.avr-sub{font-size:10px;color:var(–t2);margin-top:2px}
.avr-text.pass{color:var(–green)}
.avr-text.fail{color:var(–red)}

/* ═══════════════════════════════════════
2. SPLIT PAYMENT
═══════════════════════════════════════ */
.split-viz{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:16px;margin-bottom:12px}

.split-total{text-align:center;margin-bottom:16px}
.split-total-label{font-size:10px;font-weight:600;color:var(–t3);letter-spacing:1px;text-transform:uppercase}
.split-total-amount{font-size:32px;font-weight:700;color:var(–amber);margin-top:4px}

.split-bar{display:flex;height:12px;border-radius:6px;overflow:hidden;margin-bottom:16px;gap:2px}
.split-bar-seg{height:100%;border-radius:4px;transition:width .3s ease}

.split-methods{display:flex;flex-direction:column;gap:8px}
.split-method{display:flex;align-items:center;gap:12px;padding:12px;border-radius:var(–r);background:var(–card);border:1px solid var(–border);position:relative}
.sm-color{width:8px;height:32px;border-radius:4px;flex-shrink:0}
.sm-info{flex:1}
.sm-type{font-size:12px;font-weight:600;display:flex;align-items:center;gap:6px}
.sm-badge{font-size:9px;padding:2px 6px;border-radius:4px;font-weight:700}
.sm-amount{font-family:‘DM Mono’,monospace;font-size:14px;font-weight:700}
.sm-input{width:90px;padding:8px;border-radius:8px;background:var(–input);border:1px solid var(–border);color:var(–text);font-size:14px;font-family:‘DM Mono’,monospace;text-align:right;outline:0}
.sm-input:focus{border-color:var(–amber)}
.sm-remove{width:28px;height:28px;border-radius:50%;background:var(–red-s);border:0;color:var(–red);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sm-remove:active{transform:scale(.9)}

.split-remaining{text-align:center;padding:10px;border-radius:var(–r);margin-top:12px;font-size:12px;font-weight:600}
.split-remaining.balanced{background:var(–green-s);color:var(–green)}
.split-remaining.unbalanced{background:var(–red-s);color:var(–red)}

.add-split{display:flex;align-items:center;justify-content:center;gap:6px;padding:12px;border-radius:var(–r);border:1px dashed var(–border);color:var(–t2);font-size:12px;font-weight:600;cursor:pointer;margin-top:8px;transition:all .15s}
.add-split:active{transform:scale(.97);border-color:var(–amber);color:var(–amber)}

/* ═══════════════════════════════════════
3. OFFLINE MODE
═══════════════════════════════════════ */
.offline-status{display:flex;align-items:center;gap:12px;padding:14px 16px;border-radius:var(–r);margin-bottom:12px;font-size:13px;font-weight:600}
.offline-status.online{background:var(–green-s);border:1px solid rgba(52,199,89,.12);color:var(–green)}
.offline-status.offline{background:var(–red-s);border:1px solid rgba(255,69,58,.12);color:var(–red)}
.os-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.os-dot.on{background:var(–green);animation:pulse 2s infinite}
.os-dot.off{background:var(–red);animation:blink 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

.sync-queue{background:var(–surface);border:1px solid var(–border);border-radius:16px;overflow:hidden;margin-bottom:12px}
.sq-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(–border)}
.sq-title{font-size:13px;font-weight:700}
.sq-count{font-size:10px;font-weight:700;background:var(–amber);color:#000;padding:2px 8px;border-radius:10px}

.sq-item{display:flex;align-items:center;gap:10px;padding:10px 16px;border-bottom:1px solid var(–border)}
.sq-item:last-child{border-bottom:0}
.sq-item-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.sq-item-info{flex:1;min-width:0}
.sq-item-title{font-size:11px;font-weight:600}
.sq-item-meta{font-size:9px;color:var(–t2)}
.sq-item-status{font-size:9px;font-weight:700;padding:3px 8px;border-radius:5px}
.sq-pending{background:var(–amber-g);color:var(–amber)}
.sq-synced{background:var(–green-s);color:var(–green)}
.sq-failed{background:var(–red-s);color:var(–red)}

/* Offline flow diagram */
.flow{display:flex;flex-direction:column;gap:0;margin-bottom:12px}
.flow-step{display:flex;align-items:flex-start;gap:12px;padding:8px 0}
.flow-line{display:flex;flex-direction:column;align-items:center;width:32px;flex-shrink:0}
.flow-dot{width:10px;height:10px;border-radius:50%;border:2px solid var(–amber);background:var(–bg);flex-shrink:0;z-index:1}
.flow-dot.filled{background:var(–amber)}
.flow-connector{width:2px;flex:1;background:var(–border);min-height:20px;margin:-2px 0}
.flow-content{padding-bottom:8px}
.flow-title{font-size:12px;font-weight:700}
.flow-desc{font-size:10px;color:var(–t2);line-height:1.5;margin-top:2px}

/* Data cached indicator */
.cache-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.cache-item{padding:12px;border-radius:var(–r);background:var(–card);border:1px solid var(–border);text-align:center}
.cache-i{font-size:20px;margin-bottom:4px}
.cache-l{font-size:10px;font-weight:600;color:var(–t2)}
.cache-v{font-size:14px;font-weight:700;color:var(–text);margin-top:2px}
.cache-time{font-size:8px;color:var(–t3);margin-top:2px}

/* Toast */
.toast{position:fixed;top:56px;left:50%;transform:translateX(-50%) translateY(-20px);padding:10px 18px;border-radius:var(–r);background:var(–green);color:#000;font-size:12px;font-weight:700;z-index:2000;opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;white-space:nowrap;box-shadow:0 8px 24px rgba(52,199,89,.3)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
</style>

</head>

<script>
function switchTab(name, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('panel-' + name).classList.add('on');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ─── AGE VERIFICATION ───
function selectAgeMethod(el, method) {
  document.querySelectorAll('.ag-method').forEach(m => m.classList.remove('sel'));
  el.classList.add('sel');
  document.getElementById('ageMethodScan').style.display = method === 'scan' ? 'block' : 'none';
  document.getElementById('ageMethodManual').style.display = method === 'manual' ? 'block' : 'none';
  document.getElementById('ageMethodVisual').style.display = method === 'visual' ? 'block' : 'none';
  document.getElementById('ageResult').style.display = 'none';
  // Reset scan area
  const sa = document.getElementById('idScanArea');
  sa.className = 'id-scan-area';
  document.getElementById('idScanIcon').textContent = '🪪';
  document.getElementById('idScanText').textContent = 'Tap to simulate ID scan';
}

function simulateIdScan() {
  const area = document.getElementById('idScanArea');
  const icon = document.getElementById('idScanIcon');
  const text = document.getElementById('idScanText');

  area.className = 'id-scan-area scanning';
  icon.textContent = '⏳';
  text.textContent = 'Scanning...';

  setTimeout(() => {
    area.className = 'id-scan-area verified';
    icon.textContent = '✓';
    text.textContent = 'ID Scanned — James Wilson, DOB 05/12/1990';
    showAgeResult(true, 'ID Scan — Driver\'s License · DOB: 05/12/1990 · Age: 35');
  }, 1500);
}

function checkDob() {
  const m = document.getElementById('dobMonth').value;
  const d = document.getElementById('dobDay').value;
  const y = document.getElementById('dobYear').value;
  if (m.length === 2 && d.length === 2 && y.length === 4) {
    const dob = new Date(parseInt(y), parseInt(m) - 1, parseInt(d));
    const age = Math.floor((Date.now() - dob.getTime()) / (365.25 * 24 * 60 * 60 * 1000));
    if (age >= 21) {
      showAgeResult(true, `Manual DOB entry · ${m}/${d}/${y} · Age: ${age}`);
    } else {
      showAgeResult(false, `Customer is ${age} years old — must be 21+`);
    }
  }
}

function showAgeResult(pass, detail) {
  const el = document.getElementById('ageResult');
  el.style.display = 'block';
  el.innerHTML = `<div class="av-result ${pass ? 'pass' : 'fail'}">
    <span class="avr-icon">${pass ? '✅' : '🚫'}</span>
    <div>
      <div class="avr-text ${pass ? 'pass' : 'fail'}">${pass ? 'Verified — Sale may proceed' : 'DENIED — Sale blocked'}</div>
      <div class="avr-sub">${detail}</div>
    </div>
  </div>`;
}

// ─── SPLIT PAYMENT ───
const TOTAL = 414.81;
const COLORS = ['var(--blue)', 'var(--green)', 'var(--purple)', 'var(--amber)'];
const METHODS = [
  { icon: '💳', label: 'Visa ****4242' },
  { icon: '💵', label: 'Cash' },
  { icon: '📱', label: 'Apple Pay' },
  { icon: '💳', label: 'Amex ****1001' },
];

function recalcSplit() {
  const inputs = document.querySelectorAll('.sm-input');
  let sum = 0;
  inputs.forEach(inp => { sum += parseFloat(inp.value.replace(/[^0-9.]/g, '')) || 0; });
  const remaining = TOTAL - sum;
  const el = document.getElementById('splitRemaining');
  if (Math.abs(remaining) < 0.01) {
    el.className = 'split-remaining balanced';
    el.textContent = '✓ Balanced — $0.00 remaining';
  } else {
    el.className = 'split-remaining unbalanced';
    el.textContent = remaining > 0 ? `$${remaining.toFixed(2)} remaining` : `$${Math.abs(remaining).toFixed(2)} over — adjust amounts`;
  }
  updateSplitBar();
}

function updateSplitBar() {
  const inputs = document.querySelectorAll('.sm-input');
  const bar = document.getElementById('splitBar');
  bar.innerHTML = '';
  inputs.forEach((inp, i) => {
    const val = parseFloat(inp.value.replace(/[^0-9.]/g, '')) || 0;
    const pct = (val / TOTAL) * 100;
    const seg = document.createElement('div');
    seg.className = 'split-bar-seg';
    seg.style.width = pct + '%';
    seg.style.background = COLORS[i % COLORS.length];
    bar.appendChild(seg);
  });
}

function addSplitMethod() {
  const methods = document.getElementById('splitMethods');
  const count = methods.children.length;
  if (count >= 4) { showToast('Maximum 4 payment methods'); return; }
  const m = METHODS[count];
  const div = document.createElement('div');
  div.className = 'split-method';
  div.innerHTML = `
    <div class="sm-color" style="background:${COLORS[count]}"></div>
    <div class="sm-info"><div class="sm-type">${m.icon} ${m.label}</div></div>
    <input class="sm-input" type="text" value="$0.00" oninput="recalcSplit()">
    <button class="sm-remove" onclick="removeSplit(this)">✕</button>`;
  methods.appendChild(div);
  recalcSplit();
}

function removeSplit(btn) {
  const method = btn.closest('.split-method');
  if (document.querySelectorAll('.split-method').length <= 1) { showToast('Need at least one payment method'); return; }
  method.remove();
  recalcSplit();
}

// ─── OFFLINE MODE ───
let isOnline = true;

function toggleConnection() {
  isOnline = !isOnline;
  const el = document.getElementById('connStatus');
  const dot = document.getElementById('connDot');
  const text = document.getElementById('connText');
  if (isOnline) {
    el.className = 'offline-status online';
    dot.className = 'os-dot on';
    text.textContent = 'Online — All systems connected';
  } else {
    el.className = 'offline-status offline';
    dot.className = 'os-dot off';
    text.textContent = 'Offline — Cash only · Sync queue active';
  }
}

function simulateSync() {
  const btn = document.getElementById('syncBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Syncing...';

  const items = document.querySelectorAll('.sq-item-status');
  let i = 0;
  const interval = setInterval(() => {
    if (i < items.length) {
      items[i].textContent = 'SYNCED';
      items[i].className = 'sq-item-status sq-synced';
      i++;
    } else {
      clearInterval(interval);
      document.getElementById('sqCount').textContent = '0';
      btn.textContent = '✓ All synced';
      btn.className = 'btn btn-green';
      showToast('3 transactions synced successfully');
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = '⬆ Sync Now (0 pending)';
        btn.className = 'btn btn-amber';
      }, 2000);
    }
  }, 600);
}
</script>

